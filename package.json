{
  "name": "soksak-plugin-browser-chromium",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "description": "soksak browser plugin on the bundled Chromium engine sidecar",
  "scripts": {
    "build": "node build.mjs",
