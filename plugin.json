{
  "spec": "soksak-spec-plugin@0.0.1",
  "id": "soksak-plugin-browser-chromium",
  "name": {
    "ko": "브라우저 (Chromium)",
    "en": "Browser (Chromium)"
  },
  "version": "0.0.2",
  "description": {
    "ko": "콘텐츠 뷰로 브라우저를 렌더 — 번들 Chromium 엔진 사이드카를 앱 프로세스에 로드해 네이티브 child 로 구동(app.sidecar 채널). 네이티브 Chromium 속도, URL 바·북마크 내장. OS 웹뷰가 아니라 어디서나 동일한 번들 Chromium 엔진.",
    "en": "Renders the browser as a content view — loads the bundled Chromium engine sidecar into the app process and drives a native child over the app.sidecar channel. Native Chromium speed, built-in URL bar and bookmarks. A uniform bundled Chromium engine, not the OS webview."
  },
  "entry": "main.js",
  "implements": [
    {
      "id": "soksak-spec-plugin-browser",
      "version": "0.0.1"
    }
  ],
  "consumes": [
    {
      "id": "soksak-spec-plugin-sidebar-bookmarks",
      "range": "^0.0.1"
    },
    {
      "id": "soksak-spec-plugin-sidebar-dom-picker",
      "range": "^0.0.1"
    }
  ],
  "permissions": [
    "ui",
    "commands",
    "programs",
    "data",
    "sidecar",
    "commands:destructive",
    "webview"
  ],
  "sidecars": [
    {
      "name": "browser-chromium",
      "interface": {
        "id": "soksak-spec-sidecar-browser",
        "range": ">=0.0.1 <0.1.0"
      }
    }
  ],
  "configuration": [
    {
      "key": "homeUrl",
      "type": "string",
      "default": "about:blank",
      "title": {
        "ko": "시작 URL",
        "en": "Start URL"
      },
      "description": {
        "ko": "새 브라우저 탭이 처음 여는 주소.",
        "en": "Address a new browser tab opens to."
      }
    },
    {
      "key": "browserNewWindow",
      "type": "enum",
      "enum": [
        "tab",
        "window"
      ],
      "enumLabels": [
        {
          "ko": "새 탭",
          "en": "New tab"
        },
        {
          "ko": "새 창",
          "en": "New window"
        }
      ],
      "default": "tab",
      "title": {
        "ko": "새 링크 열기",
        "en": "Open new links in"
      },
      "description": {
        "ko": "target=_blank / window.open 새 링크를 새 탭(앱 내 브라우저 뷰)으로 연다.",
        "en": "Open target=_blank / window.open links as a new tab (in-app browser view)."
      }
    },
    {
      "key": "devtoolsScreencast",
      "type": "boolean",
      "default": false,
      "title": {
        "ko": "DevTools 화면 미리보기",
        "en": "DevTools screencast"
      },
      "description": {
        "ko": "DevTools 안에 검사 중인 페이지의 미리보기(screencast) 패널을 보여준다. 페이지가 옆 탭에 이미 보이므로 기본은 끔.",
        "en": "Show the inspected page's preview (screencast) panel inside DevTools. Off by default since the page is already visible in its own tab."
      }
    },
    {
      "key": "devtoolsOpenMode",
      "type": "enum",
      "enum": [
        "tab",
        "inline"
      ],
      "enumLabels": [
        {
          "ko": "독립 탭",
          "en": "Independent tab"
        },
        {
          "ko": "같은 탭 내부 분할",
          "en": "Split inside the tab"
        }
      ],
      "default": "tab",
      "title": {
        "ko": "DevTools 열기 방식",
        "en": "DevTools open mode"
      },
      "description": {
        "ko": "개발자 도구 버튼/devtools 명령이 여는 방식. 독립 탭 = 분할/이동 가능한 정식 탭, 내부 분할 = 브라우저 뷰 안에서 위(페이지)/아래(DevTools)로 나뉨. devtools-tab / devtools-inline 명령은 설정과 무관하게 각 방식을 강제한다.",
        "en": "How the devtools button / devtools command opens. Independent tab = a real splittable/movable tab; split inside = page on top, DevTools below within the browser view. The devtools-tab / devtools-inline commands force each mode regardless."
      }
    }
  ],
  "contributes": {
    "views": [
      {
        "id": "content",
        "title": {
          "ko": "브라우저 (Chromium)",
          "en": "Browser (Chromium)"
        },
        "icon": "🌐",
        "placements": [
          "content"
        ],
        "defaultPlacement": "content",
        "sidebar": {
          "left": [
            {
              "contract": "soksak-spec-plugin-sidebar-bookmarks",
              "range": "^0.0.1",
              "view": "list",
              "instance": "shared"
            }
          ],
          "right": [
            {
              "contract": "soksak-spec-plugin-sidebar-dom-picker",
              "range": "^0.0.1",
              "view": "selections",
              "instance": "shared"
            }
          ]
        },
        "transparent": true,
        "status": [
          "connecting",
          "error",
          "loading"
        ]
      }
    ],
    "programs": [
      {
        "id": "browser-chromium",
        "path": {
          "ko": "브라우저",
          "en": "Browser"
        },
        "title": {
          "ko": "Chromium",
          "en": "Chromium"
        },
        "kind": "view",
        "view": "content"
      }
    ],
    "commands": [
      {
        "name": "ping",
        "title": {
          "ko": "플러그인 적재/버전 확인(E2E)",
          "en": "Ping (load/version check)"
        }
      },
      {
        "name": "navigate",
        "title": {
          "ko": "URL 이동",
          "en": "Navigate to URL"
        }
      },
      {
        "name": "back",
        "title": {
          "ko": "이전 페이지",
          "en": "Go Back"
        }
      },
      {
        "name": "forward",
        "title": {
          "ko": "다음 페이지",
          "en": "Go Forward"
        }
      },
      {
        "name": "reload",
        "title": {
          "ko": "새로고침",
          "en": "Reload"
        }
      },
      {
        "name": "open",
        "title": {
          "ko": "브라우저 뷰 열기",
          "en": "Open browser view"
        }
      },
      {
        "name": "devtools",
        "title": {
          "ko": "개발자 도구 탭 열기",
          "en": "Open devtools tab"
        }
      },
      {
        "name": "stats",
        "title": {
          "ko": "엔진 child 진단",
          "en": "Engine child stats"
        }
      },
      {
        "name": "gc",
        "title": {
          "ko": "잔존 child 회수",
          "en": "Reclaim leftover engine children"
        }
      },
      {
        "name": "devtools-tab",
        "title": {
          "ko": "개발자 도구 독립 탭으로 열기",
          "en": "Open devtools as independent tab"
        }
      },
      {
        "name": "devtools-inline",
        "title": {
          "ko": "개발자 도구 탭 내부 분할 토글",
          "en": "Toggle devtools inside the tab"
        }
      },
      {
        "name": "stop",
        "title": {
          "ko": "정지",
          "en": "Stop"
        }
      },
      {
        "name": "home",
        "title": {
          "ko": "홈",
          "en": "Home"
        }
      },
      {
        "name": "eval",
        "title": "페이지 JS 실행",
        "danger": "inject"
      },
      {
        "name": "dom.text",
        "title": "페이지 텍스트"
      },
      {
        "name": "dom.html",
        "title": "페이지 HTML"
      },
      {
        "name": "dom.query",
        "title": "요소 조회"
      },
      {
        "name": "dom.click",
        "title": "요소 클릭",
        "danger": "inject"
      },
      {
        "name": "dom.fill",
        "title": "입력 채우기",
        "danger": "inject"
      },
      {
        "name": "dom.submit",
        "title": "폼 제출",
        "danger": "inject"
      },
      {
        "name": "dom.wait-for",
        "title": "요소 대기"
      }
    ],
    "nodes": [
      {
        "id": "urlbar",
        "description": {
          "ko": "URL 입력창",
          "en": "URL input bar"
        }
      },
      {
        "id": "back",
        "description": {
          "ko": "이전 버튼",
          "en": "Back button"
        }
      },
      {
        "id": "forward",
        "description": {
          "ko": "다음 버튼",
          "en": "Forward button"
        }
      },
      {
        "id": "reload",
        "description": {
          "ko": "새로고침 버튼",
          "en": "Reload button"
        }
      },
      {
        "id": "devtools",
        "description": {
          "ko": "개발자 도구 버튼",
          "en": "Developer tools button"
        }
      },
      {
        "id": "freeze",
        "description": {
          "ko": "디바이더 드래그 중 시각 연속 스탠드인(freeze-frame) 오버레이",
          "en": "Visual-continuity stand-in (freeze-frame) overlay during divider drag"
        }
      },
      {
        "id": "home",
        "description": {
          "ko": "홈",
          "en": "Home"
        }
      },
      {
        "id": "progress",
        "description": {
          "ko": "로딩 진행 바",
          "en": "Loading progress bar"
        }
      }
    ]
  }
}