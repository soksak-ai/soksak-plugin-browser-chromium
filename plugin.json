          "en": "Toggle devtools inside the tab"
        }
      },
      {
        "name": "stop",
        "title": {
          "ko": "\uc815\uc9c0",
          "en": "Stop"
        }
      },
      {
        "name": "home",
        "title": {
          "ko": "\ud648",
          "en": "Home"
        }
      },
      {
        "name": "eval",
        "title": "\ud398\uc774\uc9c0 JS \uc2e4\ud589",
        "danger": "inject"
      },
      {
        "name": "dom.text",
        "title": "\ud398\uc774\uc9c0 \ud14d\uc2a4\ud2b8"
      },
      {
        "name": "dom.html",
        "title": "\ud398\uc774\uc9c0 HTML"
      },
      {
        "name": "dom.query",
        "title": "\uc694\uc18c \uc870\ud68c"
      },
      {
        "name": "dom.click",
        "title": "\uc694\uc18c \ud074\ub9ad",
        "danger": "inject"
      },
      {
        "name": "dom.fill",
        "title": "\uc785\ub825 \ucc44\uc6b0\uae30",
        "danger": "inject"
      },
      {
        "name": "dom.submit",
        "title": "\ud3fc \uc81c\ucd9c",
