{
  "spec": "soksak-spec-plugin@0.0.1",
  "id": "soksak-plugin-browser-chromium",
  "name": {
    "ko": "\ube0c\ub77c\uc6b0\uc800 (Chromium)",
    "en": "Browser (Chromium)"
  },
  "version": "0.0.1",
  "description": {
    "ko": "\ucf58\ud150\uce20 \ubdf0\ub85c \ube0c\ub77c\uc6b0\uc800\ub97c \ub80c\ub354 \u2014 \ubc88\ub4e4 Chromium \uc5d4\uc9c4 \uc0ac\uc774\ub4dc\uce74\ub97c \uc571 \ud504\ub85c\uc138\uc2a4\uc5d0 \ub85c\ub4dc\ud574 \ub124\uc774\ud2f0\ube0c child \ub85c \uad6c\ub3d9(app.sidecar \ucc44\ub110). \ub124\uc774\ud2f0\ube0c Chromium \uc18d\ub3c4, URL \ubc14\u00b7\ubd81\ub9c8\ud06c \ub0b4\uc7a5. OS \uc6f9\ubdf0\uac00 \uc544\ub2c8\ub77c \uc5b4\ub514\uc11c\ub098 \ub3d9\uc77c\ud55c \ubc88\ub4e4 Chromium \uc5d4\uc9c4.",
    "en": "Renders the browser as a content view \u2014 loads the bundled Chromium engine sidecar into the app process and drives a native child over the app.sidecar channel. Native Chromium speed, built-in URL bar and bookmarks. A uniform bundled Chromium engine, not the OS webview."
  },
  "entry": "main.js",
  "implements": [
    {
      "id": "soksak-spec-plugin-browser",
      "version": "0.0.1"
    }
  ],
  "permissions": [
    "ui",
    "commands",
    "programs",
    "data",
    "sidecar",
    "commands:destructive",
    "webview"
  ],
  "sidecars": [
    {
      "name": "browser-chromium",
      "interface": {
        "id": "soksak-spec-sidecar-browser",
        "range": "0.0.1"
      },
      "reach": {
        "fetch": {
          "url": {
            "darwin": "https://github.com/soksak-ai/soksak-sidecar-browser-chromium/releases/download/v0.0.1/soksak-sidecar-browser-chromium-0.0.1-darwin-arm64.tar.gz"
          },
          "sha256": {
            "darwin": "88c14e79d11821f9efc9f8c139370c7a5cf3288771bda437b1f7bc596e7dc8fc"
          }
        }
      }
    }
  ],
  "configuration": [
    {
      "key": "homeUrl",
      "type": "string",
      "default": "about:blank",
      "title": {
        "ko": "\uc2dc\uc791 URL",
        "en": "Start URL"
      },
      "description": {
        "ko": "\uc0c8 \ube0c\ub77c\uc6b0\uc800 \ud0ed\uc774 \ucc98\uc74c \uc5ec\ub294 \uc8fc\uc18c.",
        "en": "Address a new browser tab opens to."
      }
    },
    {
      "key": "browserNewWindow",
      "type": "enum",
      "enum": [
        "tab",
        "window"
      ],
      "enumLabels": [
        {
          "ko": "\uc0c8 \ud0ed",
          "en": "New tab"
        },
        {
          "ko": "\uc0c8 \ucc3d",
          "en": "New window"
        }
      ],
      "default": "tab",
      "title": {
        "ko": "\uc0c8 \ub9c1\ud06c \uc5f4\uae30",
        "en": "Open new links in"
      },
      "description": {
        "ko": "target=_blank / window.open \uc0c8 \ub9c1\ud06c\ub97c \uc0c8 \ud0ed(\uc571 \ub0b4 \ube0c\ub77c\uc6b0\uc800 \ubdf0)\uc73c\ub85c \uc5f0\ub2e4.",
        "en": "Open target=_blank / window.open links as a new tab (in-app browser view)."
      }
    },
    {
      "key": "devtoolsScreencast",
      "type": "boolean",
      "default": false,
      "title": {
        "ko": "DevTools \ud654\uba74 \ubbf8\ub9ac\ubcf4\uae30",
        "en": "DevTools screencast"
      },
      "description": {
        "ko": "DevTools \uc548\uc5d0 \uac80\uc0ac \uc911\uc778 \ud398\uc774\uc9c0\uc758 \ubbf8\ub9ac\ubcf4\uae30(screencast) \ud328\ub110\uc744 \ubcf4\uc5ec\uc900\ub2e4. \ud398\uc774\uc9c0\uac00 \uc606 \ud0ed\uc5d0 \uc774\ubbf8 \ubcf4\uc774\ubbc0\ub85c \uae30\ubcf8\uc740 \ub054.",
        "en": "Show the inspected page's preview (screencast) panel inside DevTools. Off by default since the page is already visible in its own tab."
      }
    },
    {
      "key": "devtoolsOpenMode",
      "type": "enum",
      "enum": [
        "tab",
        "inline"
      ],
      "enumLabels": [
        {
          "ko": "\ub3c5\ub9bd \ud0ed",
          "en": "Independent tab"
        },
        {
          "ko": "\uac19\uc740 \ud0ed \ub0b4\ubd80 \ubd84\ud560",
          "en": "Split inside the tab"
        }
      ],
      "default": "tab",
      "title": {
        "ko": "DevTools \uc5f4\uae30 \ubc29\uc2dd",
        "en": "DevTools open mode"
      },
      "description": {
        "ko": "\uac1c\ubc1c\uc790 \ub3c4\uad6c \ubc84\ud2bc/devtools \uba85\ub839\uc774 \uc5ec\ub294 \ubc29\uc2dd. \ub3c5\ub9bd \ud0ed = \ubd84\ud560/\uc774\ub3d9 \uac00\ub2a5\ud55c \uc815\uc2dd \ud0ed, \ub0b4\ubd80 \ubd84\ud560 = \ube0c\ub77c\uc6b0\uc800 \ubdf0 \uc548\uc5d0\uc11c \uc704(\ud398\uc774\uc9c0)/\uc544\ub798(DevTools)\ub85c \ub098\ub268. devtools-tab / devtools-inline \uba85\ub839\uc740 \uc124\uc815\uacfc \ubb34\uad00\ud558\uac8c \uac01 \ubc29\uc2dd\uc744 \uac15\uc81c\ud55c\ub2e4.",
        "en": "How the devtools button / devtools command opens. Independent tab = a real splittable/movable tab; split inside = page on top, DevTools below within the browser view. The devtools-tab / devtools-inline commands force each mode regardless."
      }
    }
  ],
  "contributes": {
    "views": [
      {
        "id": "content",
        "title": {
          "ko": "\ube0c\ub77c\uc6b0\uc800 (Chromium)",
          "en": "Browser (Chromium)"
        },
        "icon": "\ud83c\udf10",
        "placements": [
          "content"
        ],
        "defaultPlacement": "content",
        "transparent": true,
        "status": [
          "connecting",
          "error",
          "loading"
        ]
      }
    ],
    "programs": [
      {
        "id": "browser-chromium",
        "path": {
          "ko": "\ube0c\ub77c\uc6b0\uc800",
          "en": "Browser"
        },
        "title": {
          "ko": "Chromium",
          "en": "Chromium"
        },
        "kind": "view",
        "view": "content"
      }
    ],
    "commands": [
      {
        "name": "ping",
        "title": {
          "ko": "\ud50c\ub7ec\uadf8\uc778 \uc801\uc7ac/\ubc84\uc804 \ud655\uc778(E2E)",
          "en": "Ping (load/version check)"
        }
      },
      {
        "name": "navigate",
        "title": {
          "ko": "URL \uc774\ub3d9",
          "en": "Navigate to URL"
        }
      },
      {
        "name": "back",
        "title": {
          "ko": "\uc774\uc804 \ud398\uc774\uc9c0",
          "en": "Go Back"
        }
      },
      {
        "name": "forward",
        "title": {
          "ko": "\ub2e4\uc74c \ud398\uc774\uc9c0",
          "en": "Go Forward"
        }
      },
      {
        "name": "reload",
        "title": {
          "ko": "\uc0c8\ub85c\uace0\uce68",
          "en": "Reload"
        }
      },
      {
        "name": "open",
        "title": {
          "ko": "\ube0c\ub77c\uc6b0\uc800 \ubdf0 \uc5f4\uae30",
          "en": "Open browser view"
        }
      },
      {
        "name": "devtools",
        "title": {
          "ko": "\uac1c\ubc1c\uc790 \ub3c4\uad6c \ud0ed \uc5f4\uae30",
          "en": "Open devtools tab"
        }
      },
      {
        "name": "stats",
        "title": {
          "ko": "\uc5d4\uc9c4 child \uc9c4\ub2e8",
          "en": "Engine child stats"
        }
      },
      {
        "name": "gc",
        "title": {
          "ko": "\uc794\uc874 child \ud68c\uc218",
          "en": "Reclaim leftover engine children"
        }
      },
      {
        "name": "devtools-tab",
        "title": {
          "ko": "\uac1c\ubc1c\uc790 \ub3c4\uad6c \ub3c5\ub9bd \ud0ed\uc73c\ub85c \uc5f4\uae30",
          "en": "Open devtools as independent tab"
        }
      },
      {
        "name": "devtools-inline",
        "title": {
